# 中转平台 API Key
OPENAI_API_KEY=your-neolink-api-key

# 中转平台 OpenAI-compatible base URL。
# 请以 NeoLink 文档为准；如果文档写的是 https://xxx/v1/chat/completions，
# 这里就填到 /v1，不要包含 /chat/completions。
OPENAI_BASE_URL=https://neolink.vnet.com/api/v1

# 如果文档给的是完整地址，也可以直接填这一项；它会优先于 OPENAI_BASE_URL。
# OPENAI_CHAT_COMPLETIONS_URL=https://neolink.vnet.com/api/v1/chat/completions

# 换成 NeoLink 控制台/文档里支持视觉输入的模型名。
OPENAI_MODEL=gpt-4o-mini

PORT=3000
